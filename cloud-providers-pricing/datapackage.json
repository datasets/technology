{
  "name": "cloud-providers-pricing",
  "title": "Cloud Providers Pricing Over Time",
  "description": "Historical pricing for cloud storage and compute services (AWS S3, GCP, Azure) from launch to present. Documents the dramatic decline in cloud infrastructure costs over two decades.",
  "status": "structured",
  "licenses": [{ "name": "ODC-PDDL-1.0", "path": "http://opendatacommons.org/licenses/pddl/", "title": "Open Data Commons Public Domain Dedication and License v1.0" }],
  "resources": [
    {
      "name": "storage_pricing",
      "path": "data/storage_pricing.csv",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "schema": {
        "fields": [
          {
            "name": "date",
            "type": "date",
            "format": "any"
          },
          {
            "name": "provider",
            "type": "string"
          },
          {
            "name": "service",
            "type": "string"
          },
          {
            "name": "price_per_gb_usd",
            "type": "number"
          }
        ]
      }
    }
  ],
  "views": [
    {
      "name": "storage-pricing-over-time",
      "title": "Cloud Storage Pricing Over Time",
      "resources": ["storage_pricing"],
      "specType": "vega-lite",
      "spec": {
        "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
        "mark": { "type": "line", "point": { "filled": true, "size": 60 } },
        "encoding": {
          "x": { "field": "date", "type": "temporal", "title": "Date" },
          "y": { "field": "price_per_gb_usd", "type": "quantitative", "title": "Price per GB (USD)" },
          "color": { "field": "provider", "type": "nominal", "legend": { "title": "Provider" } },
          "tooltip": [
            { "field": "provider", "type": "nominal", "title": "Provider" },
            { "field": "date", "type": "temporal", "title": "Date" },
            { "field": "price_per_gb_usd", "type": "quantitative", "format": ".3f", "title": "Price/GB (USD)" }
          ]
        }
      }
    }
  ]
}
